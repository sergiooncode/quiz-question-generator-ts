// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model Question {
  id                      Int             @id @default(autoincrement())
  uuid                    String          @unique @default(uuid())

  // Core question fields
  questionText            String          @map("question_text") @db.Text
  options                 Json            @default("[]") // Array of answer options
  correctOption           String          @map("correct_option") @db.VarChar(1)
  topic                   String          @db.VarChar(200)
  targetDifficultyLabel   DifficultyLevel @map("target_difficulty_label")
  answerExplanation       String?         @map("answer_explanation") @db.Text
  answerSources           Json            @default("[]") @map("answer_sources")

  // Timestamps
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")

  // Relations
  reviews                 QuestionReview[]

  @@map("questions")
  @@index([uuid])
  @@index([topic])
  @@index([targetDifficultyLabel])
  @@index([createdAt])
}

model QuestionReview {
  id                      Int             @id @default(autoincrement())
  uuid                    String          @unique @default(uuid())

  // Relation to Question
  questionId              Int             @map("question_id")
  question                Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  // Rubric scores (1-4)
  ak                      Int             @db.SmallInt  // Accessibility of Knowledge
  cl                      Int             @db.SmallInt  // Cognitive Load
  od                      Int             @db.SmallInt  // Obscurity of Distractors
  ts                      Int             @db.SmallInt  // Topic Specialization

  // Difficulty assessment
  difficultyScore         Float           @map("difficulty_score")
  difficultyLabel         DifficultyLevel @map("difficulty_label")

  // Validation flags
  isValid                 Boolean         @default(true) @map("is_valid")
  topicMismatch           Boolean         @default(false) @map("topic_mismatch")

  // Feedback arrays
  styleViolations         Json            @default("[]") @map("style_violations")
  factualConcerns         Json            @default("[]") @map("factual_concerns")

  // Raw judge output for debugging
  rawJudgeOutput          Json?           @map("raw_judge_output")

  // Timestamps
  createdAt               DateTime        @default(now()) @map("created_at")

  @@map("question_reviews")
  @@index([uuid])
  @@index([questionId])
  @@index([difficultyLabel])
  @@index([isValid])
}
