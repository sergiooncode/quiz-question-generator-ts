{
  "name": "quiz-question-generator",
  "version": "1.0.0",
  "description": "TypeScript-based quiz question generator",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch apps/cli/src/quiz.ts",
    "quiz": "tsx apps/cli/src/quiz.ts",
    "start": "node dist/apps/cli/src/quiz.js",
    "lint": "eslint . --ext .ts",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate --schema=libs/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema=libs/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=libs/db/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=libs/db/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=libs/db/prisma/schema.prisma",
    "db:seed": "tsx libs/db/prisma/seed.ts",
    "db:shell": "docker compose exec postgres psql -U quiz_user -d quiz_db"
  },
  "keywords": [
    "quiz",
    "questions",
    "generator"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/pg": "^8.16.0",
    "prisma": "^7.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "commander": "^14.0.2",
    "dotenv": "^16.0.0",
    "openai": "^4.0.0",
    "pg": "^8.16.3",
    "zod": "^3.22.0"
  }
}
